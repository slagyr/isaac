{
  "enabledPlugins": {
    "beads@beads-marketplace": true
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",

      "Bash(git:*)",
      "Bash(bd:*)",
      "Bash(clj:*)",
      "Bash(lein:*)",

      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(curl:*)",
      "Bash(open:*)"
    ]
  }
}
