;; Subproject deps.edn — lets consumers pull the spec tree (step
;; definitions, matchers, helpers) as a separate coordinate from
;; production isaac via :deps/root "spec":
;;
;;   io.github.slagyr/isaac-spec
;;     {:git/url "git@github.com:slagyr/isaac.git"
;;      :git/sha "..."
;;      :deps/root "spec"}
;;
;; Production isaac (root deps.edn) keeps :paths ["src"] and has no
;; speclj/gherclj on its classpath. Consumers that want steps add this
;; subcoord; production users never see it.
;;
;; isaac itself is NOT declared here — the consumer is expected to
;; already depend on isaac directly, and this subproject's namespaces
;; resolve against the consumer's isaac coord.
{:paths ["."]
 :deps  {speclj/speclj            {:mvn/version "3.13.0"}
         babashka/process         {:mvn/version "0.5.22"}
         io.github.slagyr/gherclj {:git/tag "v1.2.0" :git/sha "de202c8"}}}
