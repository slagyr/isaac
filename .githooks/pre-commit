#!/usr/bin/env bash
# Block commits that introduce secrets. Skips if gitleaks isn't installed,
# so first-time clones don't reject commits silently — `bb hooks:install`
# wires the hooks dir, and the README points at `brew install gitleaks`.
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not installed — skipping secret scan." >&2
  echo "             install: brew install gitleaks (or see https://github.com/gitleaks/gitleaks)" >&2
  exit 0
fi

gitleaks git --staged --redact --verbose --no-banner
