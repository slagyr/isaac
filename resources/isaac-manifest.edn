{:id             :isaac.server
 :version        "0.1.0"
 :builtin?       true
 :factory        isaac.server.module/create-module

 :berths         {:isaac.server/route             {:description "HTTP routes. :path is a clout pattern (literal segments, :name params, * wildcards). :method is :get/:post/... or :* for any-method. Prefix matching is just a trailing wildcard in the path."
                                                   :manifest    {:schema {:type :seq
                                                                          :spec {:type    :map
                                                                                 :factory isaac.server.routes/register-route-entry!
                                                                                 :schema  {:method  {:type :keyword :validations [:present?]}
                                                                                           :path    {:type :string  :validations [:present?]}
                                                                                           :handler {:type :symbol  :validations [:present?]}}}}}}
                  :isaac.server/tools             {:description "LLM tool factories."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type    :map
                                                                                       :factory isaac.tool.registry/register-tool-entry!
                                                                                       :schema  {:factory {:type :symbol :validations [:present?]}
                                                                                                 :schema  {:type :any}}}}}}
                  :isaac.server/llm-api           {:description "LLM API factories — adapters per provider API (messages, chat-completions, ollama, ...)."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type    :map
                                                                                       :factory isaac.llm.api/register-api-entry!
                                                                                       :schema  {:factory {:type :symbol :validations [:present?]}}}}}}
                  :isaac.server/slash-commands    {:description "Slash commands installed into the bridge slash registry."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type    :map
                                                                                       :factory isaac.slash.registry/register-slash-entry!
                                                                                       :schema  {:factory {:type :symbol :validations [:present?]}}}}}}
                  :isaac.server/hook              {:description "Event hooks installed into the hook registry. Per-entry factory resolves :factory and registers the returned spec via isaac.hooks/register-hook!."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type    :map
                                                                                       :factory isaac.hooks/register-hook-entry!
                                                                                       :schema  {:factory {:type :symbol :validations [:present?]}}}}}}
                  :isaac.server/provider-template {:description "Provider templates — partial provider configs that user-config :providers entries can inherit from via :type."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type   :map
                                                                                       :schema {:template {:type :map}}}}}}
                  :isaac.server/provider          {:description "Materialized LLM providers — instances usable by models. Manifest contributions are third-party modules shipping a ready-to-use provider; user-instantiated providers in the [:providers] config slot also count toward this berth (see `[:registered-in? :isaac.server/provider [:providers]]` use sites)."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type :map}}}}
                  :isaac.server/comm              {:description "Communication channels (Discord, iMessage, ACP, …). Manifest contributions name available impls and carry the per-impl factory plus user-config :schema. User-instantiated comm slots in the [:comms] config slot also count toward this berth, so `[:registered-in? :isaac.server/comm [:comms]]` accepts both manifest impl ids (the common :type values) and slot ids."
                                                   :manifest    {:schema {:type       :map
                                                                          :key-spec   {:type :keyword}
                                                                          :value-spec {:type    :map
                                                                                       :factory isaac.comm.registry/register-comm-entry!
                                                                                       :schema  {:factory       {:type :symbol :validations [:present?]}
                                                                                                 :schema        {:type :any}
                                                                                                 :configurable? {:type :boolean}}}}}}}

 :cli            [{:name        "auth"
                   :usage       "auth <subcommand> [options]"
                   :desc        "Manage authentication credentials"
                   :option-spec isaac.llm.auth.cli/option-spec
                   :help-text   isaac.llm.auth.cli/help-text
                   :run-fn      isaac.llm.auth.cli/run-fn}
                  {:name        "config"
                   :usage       "config <subcommand> [options]"
                   :desc        "Inspect and validate Isaac configuration"
                   :option-spec isaac.config.cli.command/option-spec
                   :help-text   isaac.config.cli.command/config-help
                   :run-fn      isaac.config.cli.command/run-fn}
                  {:name        "crew"
                   :usage       "crew"
                   :desc        "List configured crew members"
                   :option-spec isaac.crew.cli/option-spec
                   :run-fn      isaac.crew.cli/run-fn}
                  {:name        "hail"
                   :usage       "hail <subcommand> [options]"
                   :desc        "Produce hail records"
                   :option-spec isaac.hail.cli/hail-option-spec
                   :help-text   isaac.hail.cli/hail-help
                   :run-fn      isaac.hail.cli/run-fn}
                  {:name        "prompt"
                   :usage       "prompt -m <message> [options]"
                   :desc        "Run a single prompt turn and exit"
                   :option-spec isaac.bridge.prompt-cli/option-spec
                   :run-fn      isaac.bridge.prompt-cli/run-fn}
                  {:name        "logs"
                   :usage       "logs [options]"
                   :desc        "Tail and colorize the Isaac log file"
                   :option-spec isaac.logs.cli/option-spec
                   :run-fn      isaac.logs.cli/run-fn}
                  {:name        "server"
                   :usage       "server [options]"
                   :desc        "Start the Isaac HTTP server"
                   :option-spec isaac.server.cli/option-spec
                   :run-fn      isaac.server.cli/run-fn}
                  {:name        "service"
                   :usage       "service [options] <subcommand>"
                   :desc        "Manage Isaac as a background service"
                   :subcommands isaac.service.cli/subcommands
                   :run-fn      isaac.service.cli/run-fn}
                  {:name        "sessions"
                   :usage       "sessions [options]"
                   :desc        "List stored conversation sessions"
                   :option-spec isaac.session.cli/option-spec
                   :run-fn      isaac.session.cli/run-fn}]

 :isaac.server/route [{:method :post :path "/hail/send" :handler isaac.hail.http/handler}
                      {:method :*    :path "/hooks/*"  :handler isaac.hooks/handler}]

 :isaac.server/llm-api {:messages         {:factory isaac.llm.api.messages/make}
                        :grover           {:factory isaac.llm.api.grover/make}
                        :ollama           {:factory isaac.llm.api.ollama/make}
                        :chat-completions {:factory isaac.llm.api.chat-completions/make}
                        :responses        {:factory isaac.llm.api.responses/make}}

 :isaac.server/tools {:edit          {:factory isaac.tool.builtin/edit-tool-factory}
                      :exec          {:factory isaac.tool.builtin/exec-tool-factory}
                      :glob          {:factory isaac.tool.builtin/glob-tool-factory}
                      :grep          {:factory isaac.tool.builtin/grep-tool-factory}
                      :hail-send     {:factory isaac.tool.hail/hail-send-tool-factory}
                      :list_skills   {:factory isaac.tool.skill/list-skills-tool-factory}
                      :load_skill    {:factory isaac.tool.skill/load-skill-tool-factory}
                      :memory_get    {:factory isaac.tool.builtin/memory-get-tool-factory}
                      :memory_search {:factory isaac.tool.builtin/memory-search-tool-factory}
                      :memory_write  {:factory isaac.tool.builtin/memory-write-tool-factory}
                      :read          {:factory isaac.tool.builtin/read-tool-factory}
                      :session_info  {:factory isaac.tool.builtin/session-info-tool-factory}
                      :session_model {:factory isaac.tool.builtin/session-model-tool-factory}
                      :web_fetch     {:factory isaac.tool.builtin/web-fetch-tool-factory}
                      :web_search    {:factory isaac.tool.builtin/web-search-tool-factory
                                      :schema  {:provider {:type :keyword :validations [[:one-of? :brave]]}
                                                :api-key  {:type :string :validations [:present?]}}}
                      :write         {:factory isaac.tool.builtin/write-tool-factory :schema {}}}

 :isaac.server/provider-template {:anthropic {:template {:api      "messages"
                                                         :base-url "https://api.anthropic.com"
                                                         :auth     "api-key"}}
                                  :xai       {:template {:api      "chat-completions"
                                                         :base-url "https://api.x.ai/v1"
                                                         :auth     "api-key"}}
                                  :grover    {:template {:api  "grover"
                                                         :auth "none"}}
                                  :ollama    {:template {:api      "ollama"
                                                         :base-url "http://localhost:11434"
                                                         :auth     "none"}}
                                  :openai    {:template {:api      "chat-completions"
                                                         :base-url "https://api.openai.com/v1"
                                                         :auth     "api-key"}}
                                  :chatgpt   {:template {:api      "responses"
                                                         :base-url "https://chatgpt.com/backend-api/codex"
                                                         :auth     "oauth-device"}}}

 :isaac.server/slash-commands {:crew   {:factory isaac.slash.builtin/crew-command}
                               :cwd    {:factory isaac.slash.builtin/cwd-command}
                               :effort {:factory isaac.slash.builtin/effort-command}
                               :model  {:factory isaac.slash.builtin/model-command}
                               :status {:factory isaac.slash.builtin/status-command}}

 :isaac.config/schema
 {:acp
  {:schema
   {:name :acp,
    :type :map,
    :description "Agent Communication Protocol configuration",
    :schema
    {:proxy-max-reconnects
     {:type :int,
      :description "Maximum reconnect attempts for ACP proxy"},
     :proxy-reconnect-delay-ms
     {:type :int,
      :description
      "Base reconnect delay in milliseconds for ACP proxy"},
     :proxy-reconnect-max-delay-ms
     {:type :int,
      :description
      "Maximum reconnect delay in milliseconds for ACP proxy"}}}},
  :channels
  {:schema
   {:name :channels,
    :type :map,
    :description "Legacy communication channel configuration",
    :schema {}}},
  :command-paths
  {:schema
   {:type :seq,
    :spec {:type :string},
    :description "Extra typed roots to scan for prepared commands"}},
  :comms
  {:schema
   {:description
    "Communication channel configurations (map of name -> comm config)",
    :type :map,
    :name "comms table",
    :key-spec {:type :string},
    :value-spec
    {:name :comm,
     :type :map,
     :schema
     {:type
      {:type :id,
       :description "Manifest comm kind to instantiate",
       :validations [[:registered-in? :isaac.server/comm [:comms]]],
       :options-from :comms},
      :crew
      {:type :id,
       :description "Crew id this comm routes into",
       :validations [:crew-exists?]}}}}},
  :crew
  {:entity-dir "crew",
   :frontmatter? true,
   :merge-root-entity? true,
   :companion {:field :soul, :mode :exclusive},
   :schema
   {:description
    "Crew member configurations (map of id -> crew config)",
    :type :map,
    :name "crew table",
    :snapshot-only? true,
    :key-spec {:type :string},
    :value-spec
    {:name :crew,
     :type :map,
     :schema
     {:tags
      {:type :ignore,
       :set-type? true,
       :validations [:keyword-set?],
       :description
       "Flat set of keyword tags for discovery and routing"},
      :effort
      {:type :int,
       :description
       "Effort level override for this crew member (0-10)"},
      :tools
      {:name :tools,
       :type :map,
       :description "Tool configuration",
       :schema
       {:allow
        {:type :seq,
         :spec
         {:type :keyword,
          :validations [[:registered-in? :isaac.server/tools]]},
         :description "Allowed tool names"},
        :directories
        {:type :seq,
         :spec {:type :ignore, :validations [:cwd-or-path?]},
         :description
         "Allowed directories; :cwd expands to session cwd, strings are absolute paths"}}},
      :cwd
      {:type :string,
       :validations [:absolute-path?],
       :description "Default workdir for new sessions on this crew"},
      :soul
      {:type :string,
       :description
       "The personality of this crew member. Alternatively saved at config/crew/<id>.md"},
      :history-retention
      {:type :keyword,
       :validations [[:one-of? :prune :retain]],
       :description
       "Transcript history retention policy for new sessions"},
      :id
      {:type :id,
       :description "Crew member id; must match filename when present"},
      :context-mode
      {:type :keyword,
       :validations [[:one-of? :full :reset]],
       :description "How much transcript history to replay each turn"},
      :provider
      {:type :id,
       :description "Provider id for direct provider/model crews",
       :validations
       [[:registered-in? :isaac.server/provider [:providers]]]},
      :compaction
      {:type :map,
       :schema
       {:strategy {:type :keyword},
        :threshold
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.8 for 80% of context-window"]]},
        :head
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
        :async? {:type :boolean},
        :head-threshold
        {:type :ignore,
         :validations [[:less-than? :head :threshold]],
         :description "Derived: head must stay below threshold"}}},
      :max-in-flight
      {:type :int,
       :validations [:positive?],
       :description
       "Maximum concurrent in-flight turns for this crew member"},
      :model
      {:type :id,
       :description "ID of the model this crew member uses.",
       :validations [:model-exists?]}}}}},
  :cron
  {:entity-dir "cron",
   :frontmatter? true,
   :merge-root-entity? true,
   :companion {:field :prompt, :mode :required},
   :schema
   {:description
    "Cron job configurations (map of job name -> cron job config)",
    :type :map,
    :name "cron table",
    :key-spec {:type :string},
    :value-spec
    {:name :cron-job,
     :type :map,
     :description "Cron job configuration",
     :schema
     {:expr {:type :string, :description "5-field cron expression"},
      :crew
      {:type :id,
       :description "Crew id to run the job as",
       :validations [:crew-exists?]},
      :prompt
      {:type :string,
       :description "Prompt sent when the cron job fires"}}}}},
  :defaults
  {:schema
   {:name :defaults,
    :type :map,
    :description "Default crew and model selections",
    :schema
    {:crew
     {:type :id,
      :default "main",
      :description "Default crew member id",
      :validations [:crew-exists?]},
     :model
     {:type :id,
      :default "llama",
      :description "Default model alias",
      :validations [:model-exists?]},
     :context-mode
     {:type :keyword,
      :validations [[:one-of? :full :reset]],
      :description "Default transcript replay mode for new turns"},
     :compaction
     {:type :map,
      :schema
      {:strategy {:type :keyword},
       :threshold
       {:type :double,
        :validations
        [[:percentage? "e.g. 0.8 for 80% of context-window"]]},
       :head
       {:type :double,
        :validations
        [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
       :async? {:type :boolean},
       :head-threshold
       {:type :ignore,
        :validations [[:less-than? :head :threshold]],
        :description "Derived: head must stay below threshold"}},
      :description "Default compaction policy for sessions"},
     :history-retention
     {:type :keyword,
      :validations [[:one-of? :prune :retain]],
      :description
      "Default transcript history retention policy for new sessions"},
     :effort
     {:type :int,
      :description
      "Default effort level (0-10) when not overridden by provider/model/crew/session"}}}},
  :gateway
  {:schema
   {:name :gateway,
    :type :map,
    :description "Gateway server configuration (ACP WebSocket)",
    :schema
    {:host {:type :string, :description "Bind host"},
     :port {:type :int, :description "Bind port"}}}},
  :hail
  {:entity-dir "hail",
   :merge-root-entity? true,
   :companion {:field :prompt, :mode :optional},
   :schema
   {:name :hail,
    :type :map,
    :description "Hail band declarations",
    :snapshot-only? true,
    :key-spec {:type :string},
    :value-spec
    {:name :hail-band,
     :type :map,
     :description "Hail band declaration",
     :schema
     {:crew
      {:type :seq,
       :spec {:type :string},
       :description "Explicit crew ids eligible for the band"},
      :crew-tags
      {:type :seq,
       :spec {:type :keyword},
       :description "Tags crews must carry"},
      :session
      {:type :seq,
       :spec {:type :string},
       :description "Explicit session ids eligible for the band"},
      :session-tags
      {:type :seq,
       :spec {:type :keyword},
       :description "Tags sessions must carry"},
      :reach
      {:type :keyword,
       :validations [[:one-of? :one :all]],
       :description "How many listeners receive the hail"},
      :prompt
      {:type :string,
       :description "Optional companion markdown prompt for the band"},
      :addressing
      {:type :ignore,
       :validations
       [[:requires-any? :crew :crew-tags :session :session-tags]],
       :description
       "Derived: bands must address crews or sessions"}}}}},
  :hooks
  {:entity-dir "hooks",
   :frontmatter? true,
   :companion {:field :template, :mode :required},
   :schema
   {:name :hooks,
    :type :map,
    :description "Webhook configuration",
    :schema
    {:auth
     {:name :hook-auth,
      :type :map,
      :description "Retired webhook auth configuration",
      :schema
      {:token
       {:type :string,
        :validations [[:retired? "use :server :auth :token"]]}}}},
    :key-spec {:type :string},
    :value-spec
    {:name :hook,
     :type :map,
     :description "Webhook receiver configuration",
     :schema
     {:crew
      {:type :id,
       :description "Crew id to run the hook as",
       :validations [:crew-exists?]},
      :id
      {:type :id,
       :description "Hook id; must match filename when present"},
      :model
      {:type :id,
       :description "Optional model override for the hook session",
       :validations [:model-exists?]},
      :session-key
      {:type :string,
       :description "Session key to use for dispatched turns"},
      :template
      {:type :string,
       :description "Rendered message template for the hook body"}}}}},
  :models
  {:entity-dir "models",
   :merge-root-entity? true,
   :schema
   {:description "Model configurations (map of id -> model config)",
    :type :map,
    :name "model table",
    :snapshot-only? true,
    :key-spec {:type :string},
    :value-spec
    {:name :model,
     :type :map,
     :schema
     {:effort
      {:type :int,
       :description "Effort level override for this model (0-10)"},
      :thinking-budget-max
      {:type :int,
       :description
       "Anthropic: max thinking budget tokens at effort=10; scales linearly. Default 32000."},
      :allows-effort
      {:type :boolean,
       :description
       "Whether to attach :effort to requests for this model (default true)"},
      :history-retention
      {:type :keyword,
       :validations [[:one-of? :prune :retain]],
       :description
       "Transcript history retention policy for sessions created against this model"},
      :id
      {:type :id,
       :description "Model alias; must match filename when present"},
      :provider
      {:type :id,
       :description "Provider alias",
       :required? true,
       :validations
       [:present?
        [:registered-in? :isaac.server/provider [:providers]]]},
      :context-window
      {:type :int, :description "Context window size in tokens"},
      :think-mode
      {:type :keyword,
       :description
       "Ollama: how :effort is translated. :bool (default) → think true/false; :levels → \"low\"|\"medium\"|\"high\"."},
      :compaction
      {:type :map,
       :schema
       {:strategy {:type :keyword},
        :threshold
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.8 for 80% of context-window"]]},
        :head
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
        :async? {:type :boolean},
        :head-threshold
        {:type :ignore,
         :validations [[:less-than? :head :threshold]],
         :description "Derived: head must stay below threshold"}},
       :description "Compaction policy override for this model"},
      :model
      {:type :string,
       :description "Provider-specific model name or id",
       :required? true,
       :validations [:present?]}}}}},
  :prefer-entity-files
  {:schema
   {:type :boolean,
    :default false,
    :description
    "Prefer crew/*.edn, models/*.edn, and providers/*.edn for new entities"}},
  :prompt-dir-names
  {:schema
   {:type :map,
    :key-spec {:type :string},
    :value-spec {:type :string},
    :description
    "Directory-name to prompt-type mapping for prepared prompts"}},
  :prompt-paths
  {:schema
   {:type :seq,
    :spec {:type :string},
    :description "Extra roots to scan for prepared prompts"}},
  :providers
  {:entity-dir "providers",
   :merge-root-entity? true,
   :schema
   {:description
    "Provider configurations (map of id -> provider config)",
    :type :map,
    :name "provider table",
    :snapshot-only? true,
    :key-spec {:type :string},
    :value-spec
    {:name :provider,
     :type :map,
     :schema
     {:effort
      {:type :int,
       :description "Effort level for this provider (0-10)"},
      :assistant-base-url
      {:type :string, :description "Base URL for assistant endpoints"},
      :supports-system-role
      {:type :boolean,
       :description
       "Whether the provider accepts a system role message"},
      :api
      {:type :id,
       :description
       "Provider API adapter (e.g. \"anthropic\", \"ollama\")",
       :validations [[:registered-in? :isaac.server/llm-api]]},
      :name {:type :string, :description "Display name"},
      :response-format
      {:type :string, :description "Response format hint"},
      :type
      {:type :id,
       :description "Manifest provider id to inherit template from",
       :validations
       [[:registered-in? :isaac.server/provider-template]]},
      :auth
      {:type :string,
       :description "Authentication mode (e.g. \"oauth-device\")"},
      :base-url {:type :string, :description "API base URL"},
      :headers
      {:type :map,
       :key-spec {:type :string},
       :value-spec {:type :string},
       :description "Extra HTTP headers to include in requests"},
      :token
      {:type :string,
       :description "Authentication token (alias for api-key)"},
      :models
      {:type :seq,
       :spec {:type :string},
       :description "Canonical model ids served by this provider"},
      :auth-key {:type :string, :description "Authentication key"},
      :history-retention
      {:type :keyword,
       :validations [[:one-of? :prune :retain]],
       :description
       "Transcript history retention policy for sessions created against this provider"},
      :id
      {:type :id,
       :description "Provider id; must match filename when present"},
      :stream-supports-tool-calls
      {:type :boolean,
       :description "Whether streaming mode supports tool calls"},
      :compaction
      {:type :map,
       :schema
       {:strategy {:type :keyword},
        :threshold
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.8 for 80% of context-window"]]},
        :head
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
        :async? {:type :boolean},
        :head-threshold
        {:type :ignore,
         :validations [[:less-than? :head :threshold]],
         :description "Derived: head must stay below threshold"}},
       :description "Compaction policy override for this provider"},
      :originator
      {:type :string, :description "X-Originator header value"},
      :api-key
      {:type :string,
       :validations [[:present-when? :auth "api-key"]],
       :description "API key"}}}}},
  :server
  {:schema
   {:name :server,
    :type :map,
    :description "HTTP server configuration",
    :schema
    {:auth
     {:type :map,
      :description "Server-wide inbound auth configuration",
      :schema
      {:token
       {:type :string,
        :description "Bearer token for inbound HTTP requests"}}},
